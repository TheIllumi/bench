{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bench",
  "version": "0.1.0",
  "identifier": "com.saadm.bench",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "bench",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 450,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
